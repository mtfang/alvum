{
  "name": "alvum",
  "version": "0.1.9",
  "description": "Alvum — proactive alignment engine (Electron shell)",
  "main": "main.js",
  "author": "alvum",
  "license": "UNLICENSED",
  "scripts": {
    "renderer:check": "tsc -p tsconfig.renderer.json --noEmit",
    "renderer:build": "esbuild src/renderer/app.ts --bundle --format=iife --target=chrome124 --outfile=renderer-dist/popover.js --log-level=warning",
    "test": "npm run renderer:check && npm run renderer:build && node --test tests/*.test.js",
    "start": "npm run renderer:build && electron .",
    "pack": "npm run renderer:build && electron-builder --mac --dir && bash ../scripts/sign-app.sh dist/mac-arm64/Alvum.app",
    "dist": "npm run renderer:build && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.alvum.capture",
    "productName": "Alvum",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "icon": "assets/icon.png",
      "extendInfo": {
        "LSUIElement": true,
        "CFBundleIconName": "AppIcon",
        "NSMicrophoneUsageDescription": "Alvum records microphone audio for your daily briefing.",
        "NSScreenCaptureUsageDescription": "Alvum captures screen and system audio for your daily briefing."
      }
    },
    "files": [
      "main.js",
      "main/**/*",
      "popover.html",
      "popover-preload.js",
      "renderer-dist/**/*",
      "assets/**/*",
      "package.json",
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "argparse/**/*",
          "builder-util-runtime/**/*",
          "debug/**/*",
          "electron-updater/**/*",
          "fs-extra/**/*",
          "graceful-fs/**/*",
          "js-yaml/**/*",
          "jsonfile/**/*",
          "lazy-val/**/*",
          "lodash.escaperegexp/**/*",
          "lodash.isequal/**/*",
          "mdast-util-gfm-*/**/*",
          "micromark-extension-gfm-*/**/*",
          "micromark-util-encode/**/*",
          "micromark-util-subtokenize/**/*",
          "sax/**/*",
          "semver/**/*",
          "tiny-typed-emitter/**/*",
          "universalify/**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "../target/release/alvum",
        "to": "bin/alvum"
      },
      {
        "from": "../scripts",
        "to": "scripts"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "mtfang",
        "repo": "alvum"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "katex": "^0.16.45",
    "micromark-util-encode": "^2.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  }
}
