{
  "name": "alvum",
  "version": "0.1.0",
  "description": "Alvum — proactive alignment engine (Electron shell)",
  "main": "main.js",
  "author": "alvum",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --mac --dir",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.alvum.capture",
    "productName": "Alvum",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "Alvum records microphone audio for your daily briefing.",
        "NSScreenCaptureUsageDescription": "Alvum captures screen and system audio for your daily briefing."
      }
    },
    "files": [
      "main.js",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../target/release/alvum",
        "to": "bin/alvum"
      }
    ]
  }
}
